<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane prefHeight="506.0" prefWidth="605.0" styleClass="app-background" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.chatterbox.lan.controllers.ChatPageController">

    <BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" visible="true" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
        <left>

            <VBox prefHeight="400.0" prefWidth="280.0" BorderPane.alignment="CENTER" VBox.vgrow="ALWAYS">
                <HBox style="-fx-padding: 10;">
                    <children>
                        <Label styleClass="sidebar-title" text="Chats" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#onOpenAddFriend" styleClass="sidebar-icon-button">
                           <graphic>
                              <FontIcon iconLiteral="fas-plus" iconSize="20" styleClass="sidebar-action-icon" />
                           </graphic>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#onOpenCreateConversation" styleClass="sidebar-icon-button">
                           <graphic>
                              <FontIcon iconLiteral="fas-users" iconSize="20" styleClass="sidebar-action-icon" />
                           </graphic>
                        </Button>
                    </children>
                </HBox>
                <ListView fx:id="conversationList" prefHeight="400.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
            </VBox>
        </left>
        <center>
            <VBox>
                <HBox fx:id="chatHeader" managed="false" spacing="6" styleClass="chat-header" visible="false">
                    <children>
                        <Label fx:id="inboxLabel" styleClass="chat-header-title" text="Select a conversation" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#onStartAudioCall" styleClass="chat-header-button">
                           <graphic>
                              <FontIcon iconLiteral="fas-phone" iconSize="16" styleClass="chat-header-icon" />
                           </graphic>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#onStartVideoCall" styleClass="chat-header-button">
                           <graphic>
                              <FontIcon iconLiteral="fas-video" iconSize="16" styleClass="chat-header-icon" />
                           </graphic>
                        </Button>
                    </children>
                </HBox>
                <HBox fx:id="callNotificationBanner" managed="false" styleClass="call-notification-banner" visible="false">
                    <children>
                        <Label fx:id="callNotificationLabel" styleClass="call-notification-text" text="On call" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#onEndAudioCall" styleClass="call-end-button" text="End Call" />
                    </children>
                </HBox>
                <StackPane styleClass="message-area" VBox.vgrow="ALWAYS">
                    <children>
                        <ListView fx:id="messageList" managed="false" styleClass="message-list" visible="false" VBox.vgrow="ALWAYS" />
                        <Label fx:id="emptyStateLabel" styleClass="empty-chat-label" text="Start a conversation" />
                    </children>
                </StackPane>
                <HBox fx:id="chatComposer" managed="false" spacing="10" styleClass="chat-composer" visible="false">
                    <children>
                        <Button mnemonicParsing="false" styleClass="composer-icon-button">
                           <graphic>
                              <FontIcon iconLiteral="fas-file" iconSize="18" styleClass="composer-file-icon" />
                           </graphic>
                        </Button>
                        <TextField fx:id="inputMessage" promptText="Type a message..." styleClass="chat-input-field" HBox.hgrow="ALWAYS" />
                        <Button fx:id="sendButton" onAction="#onSendMessage" styleClass="composer-icon-button">
                           <graphic>
                              <FontIcon iconLiteral="fas-paper-plane" iconSize="18" styleClass="composer-send-icon" />
                           </graphic>
                        </Button>
                    </children>
                </HBox>
            </VBox>
        </center>
    </BorderPane>
    <VBox fx:id="createConversationOverlay" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="374.0" prefWidth="448.0" spacing="10" style="-fx-border-color: gray; -fx-background-color: white; -fx-padding: 16; -fx-background-radius: 10;" visible="false">
         <HBox alignment="CENTER_LEFT" spacing="10">
             <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Create Conversation" />
             <Pane HBox.hgrow="ALWAYS" />
             <Button onAction="#onCloseCreateConversation" text="X" />
         </HBox>

         <Label text="Conversation Name" />
         <TextField fx:id="conversationNameField" promptText="e.g. Project" />

         <Label text="Select Members" />
         <ListView fx:id="availableUsersList" prefHeight="180" />

         <HBox alignment="CENTER_RIGHT" spacing="10">
             <Button onAction="#onCloseCreateConversation" text="Cancel" />
             <Button onAction="#onSubmitCreateConversation" text="Create" />
         </HBox>
    </VBox>

    <VBox fx:id="addFriendOverlay" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="275.0" prefWidth="448.0" spacing="10" style="-fx-border-color: gray; -fx-background-color: white; -fx-padding: 16; -fx-background-radius: 10;" visible="false">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Add Friend" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button onAction="#onCloseAddFriend" text="X" />
        </HBox>

        <Label text="Friend Username" />
        <TextField fx:id="friendUserNameField" promptText="e.g. Project" />

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button onAction="#onCloseAddFriend" text="Cancel" />
            <Button onAction="#onSubmitAddFriend" text="Create" />
        </HBox>
    </VBox>
</StackPane>
